{
	"name": "@gonative-cc/btcindexer",
	"type": "module",
	"license": "MPL-2.0",
	"version": "0.0.1",
	"exports": {
		"./*": "./src/*.ts"
	},
	"scripts": {
		"dev": "wrangler dev --test-scheduled",
		"deploy": "wrangler deploy",
		"deploy:prod": "wrangler deploy -c ./wrangler-prod.jsonc",
		"db:migrate": "wrangler d1 migrations apply btcindexer-dev",
		"db:migrate:local": "wrangler d1 migrations apply btcindexer-dev --local",
		"db:migrate:backstage": "wrangler d1 migrations apply btcindexer-dev --remote",
		"typecheck": "tsc",
		"cf-typegen": "wrangler types",
		"test": "bun test",
		"seed:config": "bun run scripts/seed-config.ts"
	},
	"dependencies": {
		"@gonative-cc/lib": "workspace:*",
		"@gonative-cc/sui-indexer": "workspace:*",
		"@gonative-cc/compliance": "workspace:*",
		"@mysten/bcs": "catalog:",
		"@mysten/sui": "catalog:",
		"bitcoinjs-lib": "catalog:",
		"crypto-js": "^4.2.0",
		"itty-router": "catalog:",
		"merkletreejs": "^0.5.2"
	},
	"devDependencies": {}
}
